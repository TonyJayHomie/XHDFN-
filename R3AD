    if "/oauth/account"          in path: return LOCAL_PROFILE
    if "/oauth/token"            in path: return LOCAL_TOKEN
    if "/bootstrap"              in path: return LOCAL_BOOTSTRAP
    if "/oauth/organizations"    in path:
