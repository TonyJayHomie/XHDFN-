        self.send_header("Content-Type","application/json")
        self.send_header("Content-Length",str(len(b)))
        self.send_header("Connection","close")
        self._cors()
        self.end_headers()
        try: self.wfile.write(b)
        except OSError: pass

    def _html(self, html):
